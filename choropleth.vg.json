{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Proportion of Australian Land Area covered by Forests by State/Territory",
  "width": 800,
  "height": 400,
  "projection": {"type": "mercator"},
  "data": {
    "url": "australian_stateterritory.json",
    "format": {"type": "topojson", "feature": "STE_2016_AUST"}
  },
  "transform": [
    {
      "lookup": "properties.STE_NAME16",
      "from": {
        "data": {
          "url": "aus_forest_state.csv"
        },
        "key": "STATE",
        "fields": ["FOREST", "NON_FOREST", "ACACIA", "CALLITRIS", "CASUARINA", "EUCALYPT", "HARDWOOD", "MANGROVE", "MELALEUCA", "RAINFOREST", "SOFTWOOD", "OTHER"]
      }
    },
    {"calculate": "toNumber(datum.FOREST) + toNumber(datum.NON_FOREST)", "as": "TOTAL_AREA"},
    {"calculate": "datum.FOREST / datum.TOTAL_AREA", "as": "PROPORTION_FOREST"}
  ],
  "mark": {"type": "geoshape"},
  "encoding": {
    "color": {
      "field": "PROPORTION_FOREST",
      "type": "quantitative",
      "scale": {
        "domain": [0, 0.65],
        "scheme": "greens"
      },
      "legend": {"format": ".2%"}
    },
    "tooltip": [
      {"field": "properties.STE_NAME16", "type": "nominal", "title": "State/Territory"},
      {"field": "FOREST", "type": "quantitative", "title": "Total Area of Forests (hectares)"},
      {"field": "NON_FOREST", "type": "quantitative", "title": "Land Area (hectares)"},
      {"field": "PROPORTION_FOREST", "type": "quantitative", "title": "Proportion of Land Area covered by Forests", "format": ".2%"},
      {"field": "ACACIA", "type": "quantitative", "title": "Total Area of Acacia Forests (hectares)"},
      {"field": "CALLITRIS", "type": "quantitative", "title": "Total Area of Callitris Forests (hectares)"},
      {"field": "CASUARINA", "type": "quantitative", "title": "Total Area of Casuarina Forests (hectares)"},
      {"field": "EUCALYPT", "type": "quantitative", "title": "Total Area of Eucalypt Forests (hectares)"},
      {"field": "HARDWOOD", "type": "quantitative", "title": "Total Area of Hardwood Forests (hectares)"},
      {"field": "MANGROVE", "type": "quantitative", "title": "Total Area of Mangrove Forests (hectares)"},
      {"field": "MELALEUCA", "type": "quantitative", "title": "Total Area of Melaleuca Forests (hectares)"},
      {"field": "RAINFOREST", "type": "quantitative", "title": "Total Area of Rainforests (hectares)"},
      {"field": "SOFTWOOD", "type": "quantitative", "title": "Total Area of Softwood Forests (hectares)"},
      {"field": "OTHER", "type": "quantitative", "title": "Total Area of Other Forests (hectares)"}
    ]
  }
}