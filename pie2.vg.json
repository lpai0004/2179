{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": "Proportion of Fire Area that is Forested",
  "data": {"url": "total_aus_bushfire_area.csv"},
  "params": [
    {
      "name": "STATE_SELECTION",
      "bind": {
        "input": "select",
        "options": [
          "Total",
          "Australian Capital Territory",
          "New South Wales",
          "Northern Territory",
          "Queensland",
          "South Australia",
          "Tasmania",
          "Victoria",
          "Western Australia"
        ],
        "name": "State/Territory Selection:"
      }
    }
  ],
  "transform": [
    {"filter": "datum.STATE == (STATE_SELECTION == null ? 'Total' : STATE_SELECTION)"},
    {"calculate": "datum.FOREST", "as": "Forested area"},
    {"calculate": "datum.FIRE - datum.FOREST", "as": "Non-forested area"},
    {"fold": ["Forested area", "Non-forested area"], "as": ["FORESTED", "AREA"]},
    {"joinaggregate": [{"op": "sum", "field": "AREA", "as": "TOTAL_AREA"}]},
    {"calculate": "datum.AREA / datum.TOTAL_AREA", "as": "PROPORTION"}
  ],
  "mark": "arc",
  "height": 300,
  "encoding": {
    "theta": {"field": "AREA", "type": "quantitative", "stack":"normalize"},
    "color": {
      "field": "FORESTED", 
      "type": "nominal", 
      "title": "Area type",
      "scale": {
        "domain": ["Forested area", "Non-forested area"],
        "range": ["#631e1e", "#e05a5a"]
      }
    },
    "tooltip": [
        {"field": "STATE", "type": "nominal", "title": "State/Territory"},
        {"field": "FORESTED", "type": "nominal", "title": "Forested or non-forested"},
        {"field": "AREA", "type": "quantitative", "title": "Land Area (hectares)"},
        {"field": "PROPORTION", "type": "quantitative", "title": "Proportion of Forested Area", "format": ".2%"}
    ]
  }
}